ANTHROPIC_API_KEY=your_anthropic_api_key
# Optional: only if using embedding checks via OpenAI
OPENAI_API_KEY=your_openai_api_key
# Optional: LangSmith tracing (not required for runtime)
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_TRACING=true

# Comma-separated list of allowed origins (required in production)
# Example: chrome-extension://your_extension_id,https://your-admin-site.com
CORS_ALLOW_ORIGINS=chrome-extension://your_extension_id

# Backend guardrails
RATE_LIMIT_PER_MINUTE=120
LLM_TIMEOUT_SECONDS=20
